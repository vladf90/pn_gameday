{
   "compilerOptions": {
      "lib": [
         "es5",
         "es6",
         "es2017"
      ],
      "target": "es2017",
      "module": "commonjs",
      "moduleResolution": "node",
      "outDir": "./build",
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "sourceMap": true,
      "strict": false,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "resolveJsonModule": true
   },
   "exclude": [
      "node_modules",
      "build",
      "database"
   ]
}
