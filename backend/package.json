{
   "name": "backend",
   "version": "1.0.0",
   "main": "src/index.ts",
   "license": "MIT",
   "dependencies": {
      "bcrypt": "^4.0.1",
      "body-parser": "^1.19.0",
      "cors": "^2.8.5",
      "dotenv": "^17.2.3",
      "express": "^4.17.1",
      "express-fileupload": "^1.2.1",
      "http-status-codes": "^1.4.0",
