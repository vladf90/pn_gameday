# Application
NODE_ENV=development
PORT=20000

# Database Configuration
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_DATABASE=your_database

# JWT (base64-encoded RS256 keys — generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Logging
LOG_LEVEL=debug

# Frontend proxy target (used by vite.config.ts)
BACKEND_URL=http://localhost:20000

# Backend-specific environment variables.
# Shared variables (DB, JWT, etc.) live in the repo-root .env.example.

# SportMonks integration (ADR 0001)
# Required when SPORTMONKS_ENABLED is not "false". Never logged.
SPORTMONKS_API_TOKEN=
# Override only for staging or non-football sport APIs.
SPORTMONKS_BASE_URL=https://api.sportmonks.com/v3/football
# Plan limit per entity per hour. Used for metric/alert thresholds (issue #5).
# SportMonks enforces the actual limit.
SPORTMONKS_PLAN_HOURLY_LIMIT=2000
# Kill-switch for local dev / CI. Set to "false" to skip token validation
# and skip starting the integration entirely.
SPORTMONKS_ENABLED=true
# Polling cadence for the FixturePoller in milliseconds.
SPORTMONKS_POLL_INTERVAL_MS=5000
# Max number of fixture IDs per /fixtures/multi call. The active set is split
# into this many chunks per tick when it exceeds the limit.
SPORTMONKS_MULTI_FIXTURE_BATCH_SIZE=50
